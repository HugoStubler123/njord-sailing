{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting - Relaxed for overnight build */
    "strict": false,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": false,

    /* Path mapping */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/components/*": ["src/components/*"],
      "@/core/*": ["src/core/*"],
      "@/store/*": ["src/store/*"],
      "@/assets/*": ["assets/*"]
    },

    /* Additional strict checks */
    // Temporarily disabled for overnight build - re-enable later
    // "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    // "noUncheckedIndexedAccess": true,
    "useDefineForClassFields": true,

    /* Type checking for better DX */
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["dist", "node_modules", "electron", "tests/e2e"],
  "references": [{ "path": "./tsconfig.node.json" }, { "path": "./electron/tsconfig.json" }]
}